<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PhantomGrid</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f1115; color: #e0e2e8; line-height: 1.5; }
    .container { max-width: 1200px; margin: 0 auto; padding: 24px; }
    header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; padding-bottom: 16px; border-bottom: 1px solid #252830; }
    h1 { font-size: 24px; font-weight: 700; color: #fff; }
    h2 { font-size: 18px; font-weight: 600; margin-bottom: 16px; color: #fff; }
    .btn { background: #3b82f6; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 500; transition: background 0.15s; }
    .btn:hover { background: #2563eb; }
    .btn-red { background: #ef4444; }
    .btn-red:hover { background: #dc2626; }
    .btn-sm { padding: 6px 12px; font-size: 13px; }
    .btn-green { background: #10b981; }
    .btn-green:hover { background: #059669; }
    .card { background: #181b21; border: 1px solid #252830; border-radius: 10px; padding: 20px; margin-bottom: 24px; }
    .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 16px; }
    label { display: block; font-size: 12px; font-weight: 500; color: #9ca3af; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.3px; }
    input, select { width: 100%; background: #0f1115; border: 1px solid #2d3139; color: #e0e2e8; padding: 8px 12px; border-radius: 6px; font-size: 14px; }
    input:focus, select:focus { outline: none; border-color: #3b82f6; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th { text-align: left; padding: 10px 12px; font-size: 11px; text-transform: uppercase; color: #9ca3af; font-weight: 600; letter-spacing: 0.4px; border-bottom: 1px solid #252830; }
    td { padding: 12px; border-bottom: 1px solid #1f2229; vertical-align: middle; }
    tr:hover td { background: #1c1f26; }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
    .tag-green { background: #064e3b; color: #34d399; }
    .tag-gray { background: #1f2937; color: #9ca3af; }
    .sessions-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
    .session-card { background: #181b21; border: 1px solid #252830; border-radius: 10px; padding: 12px; }
    .session-card h4 { font-size: 14px; margin-bottom: 8px; }
    .session-card img { width: 100%; border-radius: 6px; background: #0f1115; min-height: 180px; border: 1px solid #252830; }
    .hidden { display: none; }
    .actions { display: flex; gap: 8px; }
    .mono { font-family: ui-monospace, SFMono-Regular, 'SF Mono', monospace; font-size: 12px; color: #6b7280; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>PhantomGrid</h1>
      <button class="btn" onclick="toggleForm()">+ New Profile</button>
    </header>

    <div id="notify" class="hidden" style="padding:12px 16px;border-radius:6px;margin-bottom:16px;font-size:14px;font-weight:500;"></div>

    <div id="formCard" class="card hidden">
      <h2>Create Profile</h2>
      <div class="form-grid">
        <div>
          <label>Profile Name</label>
          <input id="fName" placeholder="e.g. US-East-01">
        </div>
        <div>
          <label>User Agent</label>
          <input id="fUA" placeholder="Mozilla/5.0 ...">
        </div>
        <div>
          <label>Viewport Width</label>
          <input id="fWidth" type="number" value="1920">
        </div>
        <div>
          <label>Viewport Height</label>
          <input id="fHeight" type="number" value="1080">
        </div>
        <div>
          <label>Timezone</label>
          <input id="fTimezone" value="America/New_York">
        </div>
        <div>
          <label>Language</label>
          <input id="fLang" value="en-US">
        </div>
        <div>
          <label>Latitude</label>
          <input id="fLat" type="number" step="any" placeholder="40.7128">
        </div>
        <div>
          <label>Longitude</label>
          <input id="fLng" type="number" step="any" placeholder="-74.0060">
        </div>
        <div>
          <label>Proxy Host</label>
          <input id="fProxyHost" placeholder="127.0.0.1">
        </div>
        <div>
          <label>Proxy Port</label>
          <input id="fProxyPort" type="number" placeholder="8080">
        </div>
        <div>
          <label>Proxy Username</label>
          <input id="fProxyUser" placeholder="optional">
        </div>
        <div>
          <label>Proxy Password</label>
          <input id="fProxyPass" type="password" placeholder="optional">
        </div>
      </div>
      <button class="btn" onclick="createProfile()">Save Profile</button>
    </div>

    <div class="card">
      <h2>Active Sessions</h2>
      <div id="sessions" class="sessions-grid">
        <p style="color:#6b7280;font-size:14px;">No active sessions.</p>
      </div>
    </div>

    <div class="card">
      <h2>Profiles</h2>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Viewport</th>
            <th>Timezone</th>
            <th>Proxy</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="profileTable"></tbody>
      </table>
    </div>
  </div>

  <script>
    const activeTimers = {};
    const loadingIds = new Set();

    function notify(msg, type = 'error') {
      const el = document.getElementById('notify');
      if (!el) return;
      el.textContent = msg;
      el.style.display = 'block';
      el.style.background = type === 'error' ? '#7f1d1d' : '#064e3b';
      el.style.color = type === 'error' ? '#fca5a5' : '#34d399';
      el.style.border = `1px solid ${type === 'error' ? '#b91c1c' : '#059669'}`;
      clearTimeout(el._t);
      el._t = setTimeout(() => { el.style.display = 'none'; }, 4000);
    }

    async function api(method, url, body) {
      const opts = { method, headers: {} };
      if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
      const res = await fetch(url, opts);
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
      return data;
    }

    async function loadProfiles() {
      try {
        const profiles = await api('GET', '/api/profiles');
        const tbody = document.getElementById('profileTable');
        tbody.innerHTML = '';
        profiles.forEach(p => {
          const tr = document.createElement('tr');
          const proxy = p.proxy_host ? `${p.proxy_host}:${p.proxy_port || ''}` : '—';
          const isBusy = loadingIds.has(p.id);
          tr.innerHTML = `
            <td><strong>${p.name}</strong><br><span class="mono">${p.user_agent ? p.user_agent.slice(0,40)+'...' : 'default'}</span></td>
            <td>${p.viewport_width}×${p.viewport_height}</td>
            <td>${p.timezone || '—'}</td>
            <td>${proxy}</td>
            <td><span class="tag tag-gray" id="status-${p.id}">idle</span></td>
            <td>
              <div class="actions">
                <button class="btn btn-green btn-sm" data-pid="${p.id}" onclick="launch(${p.id})" ${isBusy?'disabled':''}>${isBusy?'Launching...':'Launch'}</button>
                <button class="btn btn-red btn-sm" data-pid="${p.id}" onclick="stop(${p.id})" ${isBusy?'disabled':''}>Stop</button>
                <button class="btn btn-sm" data-pid="${p.id}" onclick="remove(${p.id})" ${isBusy?'disabled':''}>Delete</button>
              </div>
            </td>
          `;
          tbody.appendChild(tr);
        });
      } catch (e) {
        notify(e.message, 'error');
      }
    }

    async function loadSessions() {
      try {
        const sessions = await api('GET', '/api/sessions');
        const container = document.getElementById('sessions');
        const currentIds = new Set(sessions.map(s => s.profileId));

        Object.keys(activeTimers).forEach(pid => {
          if (!currentIds.has(parseInt(pid))) {
            clearInterval(activeTimers[pid]);
            delete activeTimers[pid];
            const card = document.getElementById(`session-${pid}`);
            if (card) card.remove();
          }
        });

        if (!sessions.length) {
          if (!container.querySelector('p')) {
            container.innerHTML = '<p style="color:#6b7280;font-size:14px;">No active sessions.</p>';
          }
          return;
        }

        if (container.querySelector('p')) container.innerHTML = '';

        sessions.forEach(s => {
          let card = document.getElementById(`session-${s.profileId}`);
          if (!card) {
            card = document.createElement('div');
            card.className = 'session-card';
            card.id = `session-${s.profileId}`;
            card.innerHTML = `<h4>${s.profileName} <span class="tag tag-green">running</span></h4><img id="ss-${s.profileId}" src="" alt="screenshot">`;
            container.appendChild(card);
            if (!activeTimers[s.profileId]) {
              activeTimers[s.profileId] = setInterval(() => refreshScreenshot(s.profileId), 2000);
            }
          }
          refreshScreenshot(s.profileId);
          const badge = document.getElementById(`status-${s.profileId}`);
          if (badge) { badge.className = 'tag tag-green'; badge.textContent = 'running'; }
        });
      } catch (e) {
        console.error('loadSessions:', e.message);
      }
    }

    function refreshScreenshot(profileId) {
      const img = document.getElementById(`ss-${profileId}`);
      if (img) img.src = `/api/profiles/${profileId}/screenshot?t=${Date.now()}`;
    }

    async function createProfile() {
      const name = document.getElementById('fName').value.trim();
      if (!name) { notify('Profile name is required'); return; }

      const body = {
        name,
        user_agent: document.getElementById('fUA').value || null,
        viewport_width: parseInt(document.getElementById('fWidth').value) || 1920,
        viewport_height: parseInt(document.getElementById('fHeight').value) || 1080,
        timezone: document.getElementById('fTimezone').value || 'America/New_York',
        geolocation_lat: document.getElementById('fLat').value || null,
        geolocation_lng: document.getElementById('fLng').value || null,
        language: document.getElementById('fLang').value || 'en-US',
        proxy_host: document.getElementById('fProxyHost').value || null,
        proxy_port: document.getElementById('fProxyPort').value || null,
        proxy_username: document.getElementById('fProxyUser').value || null,
        proxy_password: document.getElementById('fProxyPass').value || null,
      };

      try {
        await api('POST', '/api/profiles', body);
        notify('Profile created', 'success');
        document.getElementById('formCard').classList.add('hidden');
        document.querySelectorAll('#formCard input').forEach(i => {
          if (['fWidth','fHeight','fTimezone','fLang'].includes(i.id)) return;
          i.value = '';
        });
        loadProfiles();
      } catch (e) {
        notify(e.message, 'error');
      }
    }

    async function launch(id) {
      if (loadingIds.has(id)) return;
      loadingIds.add(id);
      loadProfiles();
      try {
        await api('POST', `/api/profiles/${id}/launch`);
        notify('Launched', 'success');
        setTimeout(loadSessions, 500);
      } catch (e) {
        notify(e.message, 'error');
      } finally {
        loadingIds.delete(id);
        loadProfiles();
      }
    }

    async function stop(id) {
      if (loadingIds.has(id)) return;
      loadingIds.add(id);
      try {
        await api('POST', `/api/profiles/${id}/stop`);
        if (activeTimers[id]) { clearInterval(activeTimers[id]); delete activeTimers[id]; }
        const card = document.getElementById(`session-${id}`);
        if (card) card.remove();
        const badge = document.getElementById(`status-${id}`);
        if (badge) { badge.className = 'tag tag-gray'; badge.textContent = 'idle'; }
        notify('Stopped', 'success');
      } catch (e) {
        notify(e.message, 'error');
      } finally {
        loadingIds.delete(id);
        loadProfiles();
      }
    }

    async function remove(id) {
      if (!confirm('Delete this profile?')) return;
      if (loadingIds.has(id)) return;
      loadingIds.add(id);
      try {
        await api('DELETE', `/api/profiles/${id}`);
        if (activeTimers[id]) { clearInterval(activeTimers[id]); delete activeTimers[id]; }
        const card = document.getElementById(`session-${id}`);
        if (card) card.remove();
        notify('Deleted', 'success');
        loadProfiles();
      } catch (e) {
        notify(e.message, 'error');
      } finally {
        loadingIds.delete(id);
      }
    }

    function toggleForm() {
      document.getElementById('formCard').classList.toggle('hidden');
    }

    loadProfiles();
    setInterval(loadSessions, 3000);
  </script>
</body>
</html>
